# PansouAndPanCheck 环境变量配置示例

# pansou 服务地址
SEARCH_API_URL=http://127.0.0.1:8888

# PanCheck 服务校验接口地址
CHECK_API_URL=http://127.0.0.1/api/v1/links/check

# 应用端口（默认1566）
PORT=1566

# 应用主机地址（默认0.0.0.0）
HOST=0.0.0.0

# HTTP客户端超时时间（秒，默认60.0）
CLIENT_TIMEOUT=60.0

# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL，默认INFO）
LOG_LEVEL=INFO

# 是否启用认证（true/false，默认false）
AUTH_ENABLED=false

# 登录账号，格式：user1:pass1,user2:pass2
AUTH_USERS=admin:admin123

# JWT有效期（小时，默认24）
AUTH_TOKEN_EXPIRY=24

# JWT签名密钥；生产环境建议显式配置固定强随机字符串
AUTH_JWT_SECRET=please-change-me

# 是否开启调试模式（true/false，默认false）
DEBUG=false
